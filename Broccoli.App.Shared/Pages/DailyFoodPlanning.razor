@page "/daily-food-planning"
@using Broccoli.Data.Models
@using Broccoli.App.Shared.Services
@using Broccoli.Shared.Services

<AuthorizeView>
    <PageTitle>Daily Food Planning</PageTitle>

    <div class="dfp-page">

        @if (_selectedPlan is null)
        {
            <!-- ═══════════════════════════════ PLANS LIST VIEW ═══════════════════════════════ -->

            <div class="page-header">
                <h1>📅 Daily Food Planning</h1>
                <button class="btn btn-primary add-button" @onclick="CreateNewPlan">
                    <span class="icon">➕</span> New Plan
                </button>
            </div>

            @if (_isLoading)
            {
                <div class="loading-container">
                    <div class="spinner"></div>
                    <p>Loading plans…</p>
                </div>
            }
            else if (!_plans.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📅</div>
                    <h2>No daily food plans yet</h2>
                    <p>Create a plan to build reusable day-of-eating templates, track macros, and compare against your calorie targets.</p>
                    <button class="btn btn-primary" @onclick="CreateNewPlan">Create Your First Plan</button>
                </div>
            }
            else
            {
                <div class="plans-list">
                    @foreach (var plan in _plans)
                    {
                        <div class="plan-card" @onclick="() => OpenPlan(plan)">
                            <div class="plan-card-info">
                                <span class="plan-card-name">@plan.Name</span>
                                <span class="plan-card-meta">
                                    @plan.Tabs.Count tab@(plan.Tabs.Count == 1 ? "" : "s")
                                    &nbsp;·&nbsp;
                                    @plan.Tabs.Sum(t => t.Rows.Count(r => r.RowType == DailyFoodPlanRowType.FoodEntry)) food item@(plan.Tabs.Sum(t => t.Rows.Count(r => r.RowType == DailyFoodPlanRowType.FoodEntry)) == 1 ? "" : "s")
                                </span>
                            </div>
                            <div class="plan-card-actions" @onclick:stopPropagation="true">
                                <button class="btn btn-danger btn-sm"
                                        title="Delete plan"
                                        @onclick="() => DeletePlan(plan)">
                                    🗑️
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <!-- ═══════════════════════════════ PLAN EDITOR VIEW ═══════════════════════════════ -->

            <!-- Editor header -->
            <div class="editor-header">
                <button class="btn btn-outline btn-sm back-btn" @onclick="BackToPlans">
                    ← Back
                </button>

                <div class="editor-plan-name">
                    @if (_editingPlanName)
                    {
                        <input class="plan-name-input"
                               @ref="_planNameInputRef"
                               value="@_editingPlanNameValue"
                               @oninput="e => _editingPlanNameValue = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnPlanNameKeyDown"
                               @onblur="() => InvokeAsync(SavePlanName)" />
                    }
                    else
                    {
                        <h1 class="plan-title" @ondblclick="StartEditPlanName" title="Double-click to rename">
                            @_selectedPlan.Name
                        </h1>
                        <button class="btn-icon-sm" title="Rename plan" @onclick="StartEditPlanName">✏️</button>
                    }
                </div>

                <span class="save-indicator @(GetSaveStatus(_selectedPlan.Id) == "Saved ✓" ? "saved" : GetSaveStatus(_selectedPlan.Id).StartsWith("Saving") ? "saving" : GetSaveStatus(_selectedPlan.Id).StartsWith("Save failed") ? "failed" : "")">
                    @GetSaveStatus(_selectedPlan.Id)
                </span>
            </div>

            <!-- Tab bar -->
            <div class="tab-bar">
                @foreach (var planTab in _selectedPlan.Tabs)
                {
                    var isActive   = _activeTabId == planTab.Id;
                    var isRenaming = _renamingTabId == planTab.Id;

                    <div class="tab-item @(isActive ? "active" : "")"
                         @onclick="() => SelectTab(planTab.Id)">
                        @if (isRenaming)
                        {
                            <input class="tab-name-input"
                                   @ref="_tabRenameInputRef"
                                   value="@_renamingTabName"
                                   @oninput="e => _renamingTabName = e.Value?.ToString() ?? string.Empty"
                                   @onkeydown="OnTabRenameKeyDown"
                                   @onblur="() => InvokeAsync(SaveRenameTab)"
                                   @onclick:stopPropagation="true" />
                        }
                        else
                        {
                            <span class="tab-label">@planTab.Name</span>
                            <button class="tab-btn-rename"
                                    title="Rename tab"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => StartRenameTab(planTab)">
                                ✏️
                            </button>
                            @if (_selectedPlan.Tabs.Count > 1)
                            {
                                <button class="tab-btn-delete"
                                        title="Delete tab"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => DeleteTab(planTab)">
                                    ✕
                                </button>
                            }
                        }
                    </div>
                }

                <button class="tab-add-btn" @onclick="AddTab" title="Add tab">+ Tab</button>
            </div>

            <!-- Tab body -->
            @if (ActiveTab is { } tab)
            {
                <!-- Person selector -->
                <div class="tab-person-bar">
                    <label class="person-label">👤 Person (target):</label>
                    <select class="person-select"
                            value="@(tab.MacroTargetId ?? string.Empty)"
                            @onchange="OnTabPersonChanged">
                        <option value="">— None —</option>
                        @foreach (var mt in _macroTargets)
                        {
                            <option value="@mt.Id">@mt.Name</option>
                        }
                    </select>
                </div>

                <!-- Food rows table -->
                <div class="table-wrapper">
                    <table class="dfp-table">
                        <thead>
                            <tr>
                                <th class="col-drag"></th>
                                <th class="col-item">Item</th>
                                <th class="col-serving">Serving</th>
                                <th class="col-qty">Qty</th>
                                <th class="col-macro">Calories</th>
                                <th class="col-macro">Fat (g)</th>
                                <th class="col-macro">Protein (g)</th>
                                <th class="col-macro">Carbs (g)</th>
                                <th class="col-actions"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var row in tab.Rows)
                            {
                                var isDragging  = _draggingRowId  == row.Id;
                                var isDragOver  = _dragOverRowId  == row.Id;

                                @if (row.RowType == DailyFoodPlanRowType.Header)
                                {
                                    <!-- Section header row -->
                                    <tr class="header-row @(isDragging ? "row-dragging" : "") @(isDragOver ? "row-drag-over" : "")"
                                        draggable="true"
                                        @ondragstart="() => OnRowDragStart(row.Id)"
                                        @ondragend="OnRowDragEnd"
                                        @ondragover:preventDefault="true"
                                        @ondragover="() => OnRowDragOver(row.Id)"
                                        @ondragleave="OnRowDragLeave"
                                        @ondrop="() => OnRowDrop(row.Id, tab)">
                                        <td class="col-drag drag-handle" title="Drag to reorder">⠿</td>
                                        <td colspan="7">
                                            <input class="header-name-input"
                                                   value="@row.HeaderName"
                                                   placeholder="Section name…"
                                                   @onchange="e => OnHeaderNameChanged(row, e)" />
                                        </td>
                                        <td class="action-cell">
                                            <button class="btn-icon-sm" title="Delete section" @onclick="() => DeleteRow(row)">🗑️</button>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <!-- Food / recipe entry row -->
                                    var hasMissingServings = RowHasMissingServings(row);

                                    <tr class="food-row @(isDragging ? "row-dragging" : "") @(isDragOver ? "row-drag-over" : "")"
                                        draggable="true"
                                        @ondragstart="() => OnRowDragStart(row.Id)"
                                        @ondragend="OnRowDragEnd"
                                        @ondragover:preventDefault="true"
                                        @ondragover="() => OnRowDragOver(row.Id)"
                                        @ondragleave="OnRowDragLeave"
                                        @ondrop="() => OnRowDrop(row.Id, tab)">

                                        <td class="col-drag drag-handle" title="Drag to reorder">⠿</td>

                                        <!-- Item selector -->
                                        <td class="col-item">
                                            <select class="item-select"
                                                    value="@GetRowSelectValue(row)"
                                                    @onchange="e => OnFoodOrRecipeChanged(row, e)">
                                                <option value="">— Select item —</option>
                                                @if (_allRecipes.Any())
                                                {
                                                    <optgroup label="🍳 Recipes">
                                                        @foreach (var recipe in _allRecipes)
                                                        {
                                                            <option value="r:@recipe.Id">@recipe.Name@(recipe.Servings is null ? " ⚠️" : "")</option>
                                                        }
                                                    </optgroup>
                                                }
                                                @if (_allFoods.Any())
                                                {
                                                    <optgroup label="🥗 Foods">
                                                        @foreach (var food in _allFoods)
                                                        {
                                                            <option value="f:@food.Id">@food.Name (@food.Measure)</option>
                                                        }
                                                    </optgroup>
                                                }
                                            </select>
                                        </td>

                                        <!-- Serving unit -->
                                        <td class="col-serving">
                                            <input class="serving-input"
                                                   value="@row.ServingName"
                                                   placeholder="unit"
                                                   @onchange="e => OnServingChanged(row, e)" />
                                        </td>

                                        <!-- Quantity -->
                                        <td class="col-qty">
                                            <input type="number"
                                                   class="qty-input"
                                                   value="@row.Quantity"
                                                   min="0.1"
                                                   step="0.5"
                                                   @onchange="e => OnQuantityChanged(row, e)" />
                                        </td>

                                        <!-- Macro cells -->
                                        <td class="col-macro macro-value">
                                            @if (hasMissingServings)
                                            {
                                                <span title="Servings not set for this recipe — macro calculation unavailable">⚠️</span>
                                            }
                                            else
                                            {
                                                @row.Calories.ToString("F0")
                                            }
                                        </td>
                                        <td class="col-macro macro-value">
                                            @if (!hasMissingServings) { @row.Fat.ToString("F1") } else { <span>—</span> }
                                        </td>
                                        <td class="col-macro macro-value">
                                            @if (!hasMissingServings) { @row.ProteinG.ToString("F1") } else { <span>—</span> }
                                        </td>
                                        <td class="col-macro macro-value">
                                            @if (!hasMissingServings) { @row.CarbsG.ToString("F1") } else { <span>—</span> }
                                        </td>

                                        <td class="action-cell">
                                            <button class="btn-icon-sm" title="Delete row" @onclick="() => DeleteRow(row)">🗑️</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>

                        <!-- Summary footer -->
                        <tfoot>
                            <tr class="totals-row">
                                <td colspan="4"><strong>Total</strong></td>
                                <td class="macro-value"><strong>@TotalCalories(tab).ToString("F0")</strong></td>
                                <td class="macro-value"><strong>@TotalFat(tab).ToString("F1")</strong></td>
                                <td class="macro-value"><strong>@TotalProtein(tab).ToString("F1")</strong></td>
                                <td class="macro-value"><strong>@TotalCarbs(tab).ToString("F1")</strong></td>
                                <td></td>
                            </tr>

                            @if (ActiveTargetProfile is { } profile)
                            {
                                var dCal  = profile.RecommendedCalories  - TotalCalories(tab);
                                var dFat  = profile.RecommendedFatG      - TotalFat(tab);
                                var dProt = profile.RecommendedProteinG  - TotalProtein(tab);
                                var dCarb = profile.RecommendedCarbsG    - TotalCarbs(tab);

                                <tr class="to-target-row">
                                    <td colspan="4">
                                        <span class="to-target-label" title="Recommended − Actual (positive = still to eat, negative = over target)">
                                            To Target (@profile.Name)
                                        </span>
                                    </td>
                                    <td class="macro-value @GetDeltaClass(dCal,  profile.RecommendedCalories)">
                                        @(dCal  >= 0 ? "+" : "")@dCal.ToString("F0")
                                    </td>
                                    <td class="macro-value @GetDeltaClass(dFat,  profile.RecommendedFatG)">
                                        @(dFat  >= 0 ? "+" : "")@dFat.ToString("F1")
                                    </td>
                                    <td class="macro-value @GetDeltaClass(dProt, profile.RecommendedProteinG)">
                                        @(dProt >= 0 ? "+" : "")@dProt.ToString("F1")
                                    </td>
                                    <td class="macro-value @GetDeltaClass(dCarb, profile.RecommendedCarbsG)">
                                        @(dCarb >= 0 ? "+" : "")@dCarb.ToString("F1")
                                    </td>
                                    <td></td>
                                </tr>
                            }
                        </tfoot>
                    </table>
                </div>

                <!-- Row action buttons -->
                <div class="row-actions">
                    <button class="btn btn-secondary btn-sm" @onclick="AddFoodRow">➕ Add Row</button>
                    <button class="btn btn-outline btn-sm" @onclick="AddHeaderRow">📌 Add Header</button>
                </div>
            }
            else
            {
                <div class="empty-tabs-hint">
                    <p>This plan has no tabs. <button class="btn btn-secondary btn-sm" @onclick="AddTab">Add a tab</button> to get started.</p>
                </div>
            }
        }

    </div>
</AuthorizeView>





