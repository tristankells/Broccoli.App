@page "/foods"
@using Broccoli.Data.Models
@using Broccoli.Shared.Services
@using Broccoli.App.Shared.Configuration
@using Broccoli.App.Shared.Components
@inject IFoodService FoodService
@inject FeatureFlagsSettings FeatureFlags

<AuthorizeView>
    <PageTitle>Foods</PageTitle>

    <h1>Food Database</h1>

    <p>Browse all available foods in the database.</p>

    @if (FeatureFlags.FoodDatabaseEditing)
    {
        <div class="page-action-bar mb-3">
            <button class="btn btn-outline-primary" @onclick="() => _usdaDialogVisible = true">
                🔍 Search USDA
            </button>
        </div>
    }

    @if (_foods == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!_foods.Any())
    {
        <p><em>No foods found.</em></p>
    }
    else
    {
        <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
            <table class="table table-striped table-hover food-table">
                <thead class="sticky-top bg-light">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Measure</th>
                    <th>g/Measure</th>
                    <th>Cal</th>
                    <th>Fat g</th>
                    <th>Sat.Fat g</th>
                    <th>Carbs g</th>
                    <th>Fiber g</th>
                    <th>Sugars g</th>
                    <th>Protein g</th>
                    <th>Na mg</th>
                    <th>Notes</th>
                    @if (FeatureFlags.FoodDatabaseEditing)
                    {
                        <th>Actions</th>
                    }
                </tr>
                </thead>
                <tbody>
                @foreach (var food in _foods)
                {
                    @if (FeatureFlags.FoodDatabaseEditing && _editingFood?.Id == food.Id)
                    {
                        <tr class="editing-row">
                            <td>@food.Id</td>
                            <td><input class="edit-input" @bind="_editingFood!.Name" /></td>
                            <td><input class="edit-input" @bind="_editingFood!.Measure" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.1" @bind="_editingFood!.GramsPerMeasure" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.1" @bind="_editingFood!.CaloriesPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.FatPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.SaturatedFatPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.CarbohydratesPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.DietaryFiberPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.SugarsPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.01" @bind="_editingFood!.ProteinPer100g" /></td>
                            <td><input class="edit-input num-input" type="number" step="0.1" @bind="_editingFood!.SodiumMgPer100g" /></td>
                            <td><input class="edit-input" @bind="_editingFood!.Notes" /></td>
                            <td class="actions-cell">
                                <button class="btn-icon btn-success-icon" @onclick="SaveEdit" title="Save">✅</button>
                                <button class="btn-icon" @onclick="CancelEdit" title="Cancel">✕</button>
                            </td>
                        </tr>
                    }
                    else if (FeatureFlags.FoodDatabaseEditing && _deletingFood?.Id == food.Id)
                    {
                        <tr class="delete-confirm-row">
                            <td colspan="14">
                                Delete <strong>@_deletingFood!.Name</strong>?
                                <button class="btn btn-sm btn-danger ms-2" @onclick="ConfirmDelete">Confirm</button>
                                <button class="btn btn-sm btn-secondary ms-1" @onclick="CancelDelete">Cancel</button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@food.Id</td>
                            <td>@food.Name</td>
                            <td>@food.Measure</td>
                            <td>@food.GramsPerMeasure.ToString("F1")</td>
                            <td>@food.CaloriesPer100g.ToString("F1")</td>
                            <td>@food.FatPer100g.ToString("F2")</td>
                            <td>@food.SaturatedFatPer100g.ToString("F2")</td>
                            <td>@food.CarbohydratesPer100g.ToString("F2")</td>
                            <td>@food.DietaryFiberPer100g.ToString("F2")</td>
                            <td>@food.SugarsPer100g.ToString("F2")</td>
                            <td>@food.ProteinPer100g.ToString("F2")</td>
                            <td>@food.SodiumMgPer100g.ToString("F1")</td>
                            <td>@food.Notes</td>
                            @if (FeatureFlags.FoodDatabaseEditing)
                            {
                                <td class="actions-cell">
                                    <button class="btn-icon" @onclick="() => StartEdit(food)" title="Edit">✏️</button>
                                    <button class="btn-icon btn-danger-icon" @onclick="() => StartDelete(food)" title="Delete">🗑️</button>
                                </td>
                            }
                        </tr>
                    }
                }

                @if (FeatureFlags.FoodDatabaseEditing)
                {
                    <tr class="add-row">
                        <td>—</td>
                        <td><input class="edit-input" @bind="_newFood.Name" placeholder="Name*" /></td>
                        <td><input class="edit-input" @bind="_newFood.Measure" placeholder="Measure" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.1" @bind="_newFood.GramsPerMeasure" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.1" @bind="_newFood.CaloriesPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.FatPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.SaturatedFatPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.CarbohydratesPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.DietaryFiberPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.SugarsPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.01" @bind="_newFood.ProteinPer100g" /></td>
                        <td><input class="edit-input num-input" type="number" step="0.1" @bind="_newFood.SodiumMgPer100g" /></td>
                        <td><input class="edit-input" @bind="_newFood.Notes" placeholder="Notes" /></td>
                        <td class="actions-cell">
                            <button class="btn btn-sm btn-primary"
                                    @onclick="AddFood"
                                    disabled="@string.IsNullOrWhiteSpace(_newFood.Name)">
                                ➕ Add
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <p class="mt-3"><strong>Total foods: @_foods.Count</strong></p>
    }

    @if (FeatureFlags.FoodDatabaseEditing)
    {
        <UsdaSearchDialog IsVisible="_usdaDialogVisible"
                          OnImport="OnUsdaImport"
                          OnCancel="() => _usdaDialogVisible = false" />
    }
</AuthorizeView>

