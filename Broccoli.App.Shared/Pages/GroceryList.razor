@page "/grocery-list"
@using Broccoli.Data.Models
@using Broccoli.App.Shared.Services
@using Broccoli.App.Shared.Components
@inject IGroceryListService GroceryListService
@inject IAuthenticationStateService AuthStateService
@inject IJSRuntime JSRuntime

<AuthorizeView>
    <PageTitle>Grocery List</PageTitle>

    <div class="grocery-list-page">
        <div class="page-header">
            <h1>🛒 Grocery List</h1>
            @if (groceryItems.Any())
            {
                <button class="btn btn-outline-secondary copy-button" @onclick="CopyToClipboard" title="Copy all items to clipboard">
                    📋 Copy to Clipboard
                </button>
                <button class="btn btn-outline-danger reset-button" @onclick="ResetList">
                    🗑️ Reset List
                </button>
            }
        </div>

        <div class="add-item-form">
            <input type="text"
                   class="form-control"
                   placeholder="Add an item..."
                   @bind="newItemName"
                   @bind:event="oninput"
                   @onkeyup="OnNewItemKeyUp"
                   maxlength="200" />
            <button class="btn btn-primary"
                    @onclick="AddItem"
                    disabled="@(string.IsNullOrWhiteSpace(newItemName) || isAdding)">
                @if (isAdding)
                {
                    <span>Adding...</span>
                }
                else
                {
                    <span>Add</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @errorMessage
            </div>
        }

        @if (isLoading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
                <p>Loading grocery list...</p>
            </div>
        }
        else if (!groceryItems.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <h2>Your grocery list is empty</h2>
                <p>Add items above or use the <strong>🛒 Add to List</strong> button on any recipe card.</p>
            </div>
        }
        else
        {
            <div class="grocery-stats">
                @{
                    var checkedCount = groceryItems.Count(i => i.IsChecked);
                }
                @checkedCount of @groceryItems.Count items checked
            </div>

            <ul class="grocery-list">
                @foreach (var item in groceryItems)
                {
                    <li class="grocery-item @(item.IsChecked ? "checked" : "")">
                        <label class="grocery-label">
                            <input type="checkbox"
                                   class="grocery-checkbox"
                                   checked="@item.IsChecked"
                                   @onchange="() => ToggleItem(item)" />
                            <span class="grocery-name">@item.Name</span>
                        </label>
                        <button class="btn-icon btn-danger delete-btn"
                                @onclick="() => DeleteItem(item)"
                                title="Remove item">
                            🗑️
                        </button>
                    </li>
                }
            </ul>
        }
    </div>
</AuthorizeView>