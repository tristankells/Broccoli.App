@page "/pantry"
@using Broccoli.Data.Models
@inject IPantryService PantryService
@inject IAuthenticationStateService AuthStateService

<AuthorizeView>
    <PageTitle>My Pantry</PageTitle>

    <div class="pantry-page">
        <div class="page-header">
            <h1>🗄️ My Pantry</h1>
        </div>

        <div class="add-item-form">
            <input type="text"
                   class="form-control"
                   placeholder="Add a pantry item..."
                   @bind="newItemName"
                   @bind:event="oninput"
                   @onkeyup="OnNewItemKeyUp"
                   maxlength="200" />
            <select class="form-select category-select" @bind="newItemCategory">
                <option value="@PantryCategory.CheckIfHave">Check If Have</option>
                <option value="@PantryCategory.AlwaysHave">Always Have</option>
            </select>
            <button class="btn btn-primary"
                    @onclick="AddItem"
                    disabled="@(string.IsNullOrWhiteSpace(newItemName) || isAdding)">
                @if (isAdding)
                {
                    <span>Adding...</span>
                }
                else
                {
                    <span>Add</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @errorMessage
            </div>
        }

        @if (isLoading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
                <p>Loading pantry...</p>
            </div>
        }
        else if (!pantryItems.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🗄️</div>
                <h2>Your pantry is empty</h2>
                <p>Add items you always have at home (like salt, flour, oil) or optional items you sometimes have.</p>
            </div>
        }
        else
        {
            @if (AlwaysHaveItems.Any())
            {
                <div class="category-section">
                    <h3 class="category-heading always-have-heading">
                        <span class="category-badge always-have-badge">✓ Always Have</span>
                        <span class="category-count">@AlwaysHaveItems.Count() items</span>
                    </h3>
                    <ul class="pantry-list">
                        @foreach (var item in AlwaysHaveItems)
                        {
                            <li class="pantry-item always-have">
                                <span class="pantry-name">@item.Name</span>
                                <div class="pantry-actions">
                                    <select class="form-select form-select-sm category-dropdown"
                                            value="@item.Category"
                                            @onchange="(e) => ChangeCategoryAsync(item, e)">
                                        <option value="@PantryCategory.AlwaysHave">Always Have</option>
                                        <option value="@PantryCategory.CheckIfHave">Check If Have</option>
                                    </select>
                                    <button class="btn-icon btn-danger delete-btn"
                                            @onclick="() => DeleteItem(item)"
                                            title="Remove from pantry">
                                        🗑️
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (CheckIfHaveItems.Any())
            {
                <div class="category-section">
                    <h3 class="category-heading check-if-have-heading">
                        <span class="category-badge check-if-have-badge">? Check If Have</span>
                        <span class="category-count">@CheckIfHaveItems.Count() items</span>
                    </h3>
                    <ul class="pantry-list">
                        @foreach (var item in CheckIfHaveItems)
                        {
                            <li class="pantry-item check-if-have">
                                <span class="pantry-name">@item.Name</span>
                                <div class="pantry-actions">
                                    <select class="form-select form-select-sm category-dropdown"
                                            value="@item.Category"
                                            @onchange="(e) => ChangeCategoryAsync(item, e)">
                                        <option value="@PantryCategory.AlwaysHave">Always Have</option>
                                        <option value="@PantryCategory.CheckIfHave">Check If Have</option>
                                    </select>
                                    <button class="btn-icon btn-danger delete-btn"
                                            @onclick="() => DeleteItem(item)"
                                            title="Remove from pantry">
                                        🗑️
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</AuthorizeView>